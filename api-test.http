############################################################
# 어디가지(Where) API 통합 테스트 스크립트
############################################################

@baseUrl = http://localhost:3000/api/v1
@contentType = application/json

# ==========================================================
# 01. 인증 (Authentication)
# ==========================================================

# @name signup
POST {{baseUrl}}/auth/signup
Content-Type: {{contentType}}

{
  "username": "kwanhun123",
  "password": "password123"
}

### --------------------------------------------------------

# @name login
# [주의] 아래 버튼을 눌러 성공(200 OK)해야만 authToken 상자가 채워집니다!
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "username": "kwanhun123",
  "password": "password123"
}

### 로그인 결과에서 토큰 상속 (변수 선언 위치 중요)
# 서버 응답 구조가 {"token": "..."} 라면 아래 그대로 쓰시면 됩니다.
@authToken = {{login.response.body.token}}

### --------------------------------------------------------

### [인증 확인] 프로필 조회 (마패 테스트)
GET {{baseUrl}}/auth/profile
Authorization: Bearer {{authToken}}


# ==========================================================
# 02. 맛집 검색 & 트렌드 (Recommend & Trends)
# ==========================================================

### 실시간 트렌드
GET {{baseUrl}}/trends

### 일반 키워드 검색
GET {{baseUrl}}/recommend?location=용봉동&food=돈까스

### 거리순 주변 검색 (광주역 인근 기준)
GET {{baseUrl}}/recommend/nearby?lat=35.1760&lng=126.9095&radius=1


# ==========================================================
# 03. 리뷰 (Review) - 3계층 & Joi 적용
# ==========================================================

### [성공] 리뷰 작성
POST {{baseUrl}}/review
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "restaurantId": "1282118673",
  "rating": 5,
  "comment": "리팩토링 후 테스트입니다. 맛집 인정!"
}

### [실패] Joi 방어막 테스트 (별점 6점 입력) -> 400 에러 기대
POST {{baseUrl}}/review
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "restaurantId": "1282118673",
  "rating": 6,
  "comment": "별점이 너무 높아요!"
}


# ==========================================================
# 04. 찜하기 (Favorite)
# ==========================================================

### 맛집 찜 추가
POST {{baseUrl}}/favorite
Authorization: Bearer {{authToken}}
Content-Type: {{contentType}}

{
  "restaurantId": "1282118673"
}

### 내 찜 목록 (페이징)
GET {{baseUrl}}/favorite/list?page=1&limit=5
Authorization: Bearer {{authToken}}


# ==========================================================
# 05. AI 챗봇 & 예외 처리
# ==========================================================

### 챗봇 메뉴 추천
POST {{baseUrl}}/chatbot/recommend
Content-Type: {{contentType}}

{
  "location": "용봉동",
  "tags": ["혼밥", "가성비"]
}

### [404] 잘못된 경로 테스트
GET {{baseUrl}}/no-where
